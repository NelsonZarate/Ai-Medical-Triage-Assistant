# --- API Keys ---
OPENAI_API_KEY="sk-..." # Necessário para o CrewAI
OPENAI_MODEL_NAME="example-model" # Exemplo, pode ser gpt-4o-mini ou outro modelo compatível

# --- FastAPI Config ---
ENVIRONMENT="development"
PORT=8000

# --- Database Config ---
# Exemplo para PostgreSQL no Docker
DATABASE_URL="postgresql://user:password@localhost:5432/medical_db"